# Copy this file to .env.local and fill in the values

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Google OAuth (same client ID/secret as the FastAPI backend)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# FastAPI backend URL (server-side only, never exposed to browser)
API_URL=http://localhost:8000

# Public API URL (for client-side reads like the event feed)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Your admin password (same as ADMIN_PASSWORD in the FastAPI .env)
ADMIN_PASSWORD=your_admin_password

# Comma-separated .edu emails that get club_admin role
CLUB_ADMIN_EMAILS=you@yourschool.edu

# Your own email — grants access to the system admin dashboard at /admin
ADMIN_EMAILS=you@email.com
